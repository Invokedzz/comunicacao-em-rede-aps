@page "/"

<div class="home-wrapper">
    <div class="home-content">
        <div class="home-logo">🌊</div>
        <h1 class="home-title">Sistema de Monitoramento</h1>
        <h2 class="home-subtitle">Rio Tietê</h2>
        <p class="home-desc">Plataforma de comunicação em tempo real para equipes de inspeção ambiental ao longo do Rio Tietê.</p>

        <div class="home-buttons">
            <a href="/login" class="btn-primary">Entrar no Sistema</a>
            <a href="/register" class="btn-secondary">Criar Conta</a>
        </div>
    </div>
</div>

<style>
